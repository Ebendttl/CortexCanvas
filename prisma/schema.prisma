generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  documents     Document[]
  createdAt     DateTime    @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// SQLite doesn't support enums natively, using String with defaults
// enum ProcessingStatus {
//   PENDING
//   PROCESSING
//   COMPLETED
//   FAILED
// }

model Document {
  id            String           @id @default(cuid())
  title         String           @default("Untitled")
  content       String?
  ownerId       String
  owner         User             @relation(fields: [ownerId], references: [id])
  blocks        DocumentBlock[]
  embeddings    Embedding[]
  versions      DocumentVersion[]
  activities    Activity[]
  tags          Tag[]
  summary       String?
  keyInsights   String?            // Array of strings
  category      String?
  status        String           @default("PENDING")
  fileType      String?
  fileSize      Int?
  fileUrl       String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String?
  fileUrl    String?
  version    Int
  createdAt  DateTime @default(now())
}

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  color     String?
  documents Document[]
}

model Activity {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  type       String   // UPLOADED, EDITED, VIEWED, DELETED, SHARED, AI_PROCESSED
  metadata   String?
  createdAt  DateTime @default(now())
}

model DocumentBlock {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  type       String
  content    String
  position   Int
}

model Embedding {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  vector     String?
  textChunk  String
}
